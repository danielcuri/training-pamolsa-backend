// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum OperationPriority {
  CRITICAL
  SEMI_CRITICAL
  NON_CRITICAL
}

enum TrainingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum TrainingResult {
  PASSED
  FAILED
}

enum PeriodStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum Role {
  ADMIN
  COLLABORATOR
  SUPERVISOR
  SUPERADMIN
}

model Project {
  id     String       @id @default(uuid())
  name   String
  status RecordStatus @default(ACTIVE)

  areas Area[]
  users User[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  trainingTemplates TrainingTemplate[]

  @@map("projects")
}

model Area {
  id     String       @id @default(uuid())
  name   String
  status RecordStatus @default(ACTIVE)

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  operations AreaOperation[]
  users      User[]
  templates  TrainingTemplate[]

  @@map("areas")
}

model AreaOperation {
  id            String            @id @default(uuid())
  name          String
  description   String?
  priority      OperationPriority
  weightPercent Float?            @map("weight_percent")

  status RecordStatus @default(ACTIVE)

  areaId String @map("area_id")
  area   Area   @relation(fields: [areaId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  templateOps TemplateOperation[]

  @@map("area_operations")
}

model User {
  id String @id @default(uuid())

  name     String
  email    String? @unique
  dni      String? @unique
  password String?

  educationLevel String?   @map("education_level")
  hireDate       DateTime? @map("hire_date")
  role           Role      @default(SUPERADMIN)

  status RecordStatus @default(ACTIVE)

  projectId String? @map("project_id")
  areaId    String? @map("area_id")

  project Project? @relation(fields: [projectId], references: [id])
  area    Area?    @relation(fields: [areaId], references: [id])

  trainings Training[]

  evaluationsDone TrainingEvaluation[] @relation("Evaluator")
  evaluatedLogs   TrainingLog[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("users")
}

model TrainingTemplate {
  id String @id @default(uuid())

  name    String
  version Int    @default(1)

  periodDurationDays Int? @map("period_duration_days")
  totalPeriods       Int? @map("total_periods")

  minimumPassingScore Float? @map("minimum_passing_score")

  certificateTemplatePdf String? @map("certificate_template_pdf")

  status RecordStatus @default(ACTIVE)

  areaId String @map("area_id")
  area   Area   @relation(fields: [areaId], references: [id])

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id])

  operations TemplateOperation[]
  trainings  Training[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([projectId])
  @@index([areaId])
  @@map("training_templates")
}

model TemplateOperation {
  id String @id @default(uuid())

  name        String
  description String?

  priority      OperationPriority
  weightPercent Float?            @map("weight_percent")

  order Int?

  minimumScore Float? @map("minimum_score")

  templateId String           @map("template_id")
  template   TrainingTemplate @relation(fields: [templateId], references: [id])

  areaOperationId String?        @map("area_operation_id")
  areaOperation   AreaOperation? @relation(fields: [areaOperationId], references: [id])

  logs        TrainingLog[]
  evaluations EvaluationDetail[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("template_operations")
}

model Training {
  id String @id @default(uuid())

  userId     String @map("user_id")
  templateId String @map("template_id")

  startDate DateTime? @map("start_date")

  status TrainingStatus  @default(NOT_STARTED)
  result TrainingResult?

  user     User             @relation(fields: [userId], references: [id])
  template TrainingTemplate @relation(fields: [templateId], references: [id])

  periods     TrainingPeriod[]
  evaluations TrainingEvaluation[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("trainings")
}

model TrainingPeriod {
  id String @id @default(uuid())

  trainingId   String @map("training_id")
  periodNumber Int    @map("period_number")

  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")

  status PeriodStatus

  training Training @relation(fields: [trainingId], references: [id])

  logs      TrainingLog[]
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  deletedAt DateTime?     @map("deleted_at")

  @@index([trainingId])
  @@map("training_periods")
}

model TrainingLog {
  id String @id @default(uuid())

  trainingPeriodId    String @map("training_period_id")
  templateOperationId String @map("template_operation_id")

  score Float?

  checklist String?

  notes String?

  evaluatorId String? @map("evaluator_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  period    TrainingPeriod    @relation(fields: [trainingPeriodId], references: [id])
  operation TemplateOperation @relation(fields: [templateOperationId], references: [id])
  evaluator User?             @relation(fields: [evaluatorId], references: [id])

  @@index([trainingPeriodId])
  @@map("training_logs")
}

model TrainingEvaluation {
  id String @id @default(uuid())

  trainingId     String    @map("training_id")
  evaluationDate DateTime? @map("evaluation_date")

  finalScore Float? @map("final_score")

  result TrainingResult?

  notes String?

  evaluatorId String? @map("evaluator_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  training  Training @relation(fields: [trainingId], references: [id])
  evaluator User?    @relation("Evaluator", fields: [evaluatorId], references: [id])

  details EvaluationDetail[]

  @@map("training_evaluations")
}

model EvaluationDetail {
  id String @id @default(uuid())

  evaluationId        String @map("evaluation_id")
  templateOperationId String @map("template_operation_id")

  score Float?

  evaluatorId Int? @map("evaluator_id")

  evaluation TrainingEvaluation @relation(fields: [evaluationId], references: [id])
  operation  TemplateOperation  @relation(fields: [templateOperationId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("evaluation_details")
}
